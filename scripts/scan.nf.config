	beforeScript = 'source /projects/ag-schwarzr/software/mamba_init.sh'
	memory = '16 GB'
	time = '00:30:00'
	cpus = 1
	clusterOptions = "--mail-user='${params.user}@uni-koeln.de' --mail-type=NONE -e /dev/null  -o /dev/null" 
}

executor {
	account = "${params.account}"
	jobName = "${params.job_name}"
	queueSize = 100
}
