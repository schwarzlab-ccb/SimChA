conda.enabled = true
report.overwrite = true
process {
	executor = 'slurm'
	conda = '/projects/ag-schwarzr/project-simcha/simcha/simcha.yml'
	beforeScript = 'source /projects/ag-schwarzr/software/mamba_init.sh'
	memory = '10 GB'
	time = '30h'
	cpus = 1
}

executor {
	name = 'slurm'
	submitRateLimit = '10/sec'
}

